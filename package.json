{
  "name": "ledgerline",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Bitemporal energy-billing engine — idempotent ingestion, versioned tariffs, a double-entry ledger, and a history the database itself enforces.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "pgtest": "vitest run --config vitest.pg.config.ts",
    "db:migrate": "node --experimental-strip-types scripts/migrate.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.1",
    "@upstash/qstash": "^2.8.1",
    "@upstash/redis": "^1.38.0",
    "@vercel/otel": "^2.1.3",
    "clsx": "^2.1.1",
    "geist": "^1.7.2",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@opentelemetry/api": "^1.9.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.37.0",
    "eslint-config-next": "^16.2.10",
    "fast-check": "^4.1.1",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true,
    "sharp@0.34.5": true
  }
}

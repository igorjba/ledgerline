# LedgerLine environment.
#
# The demo runs with ZERO configuration — the billing core runs client-side and
# every server route falls back to an in-memory repository. The variables below
# switch the same code onto real infrastructure, one capability at a time.

# Optional: Neon (or any Postgres 15+). When set, the API and the outbox use
# Postgres, and the bitemporal history is enforced by an EXCLUDE gist constraint
# instead of application code. Create a free database at https://neon.tech.
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Optional: Upstash QStash drains the transactional outbox with retries and
# signature verification. Without it, the relay marks events locally (no-op
# publish). Create a free project at https://upstash.com/qstash.
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=

# Optional: absolute base URL QStash calls back into (defaults to the request
# origin / VERCEL_URL). Set when running the relay behind a tunnel locally.
# QSTASH_TARGET_URL=

# Protects /api/outbox/drain so only the daily Vercel cron (and your own tooling)
# can trigger the relay. Vercel injects this into cron requests automatically.
# The route is fail-closed: with this unset, /api/outbox/drain is disabled (503).
# The best-effort relay after each ingestion runs in-process and is unaffected.
CRON_SECRET=

# Optional: Upstash Redis for shareable console scenarios (/api/scenario).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Surfaced by /api/health. Vercel sets VERCEL_GIT_COMMIT_SHA for you.
NEXT_PUBLIC_APP_VERSION=dev
